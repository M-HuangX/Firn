# === Active Provider (change this line to switch LLM) ===
LLM_PROVIDER=deepseek

# === DeepSeek ===
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash

# === OpenAI ===
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o

# === Gemini ===
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.5-flash

# === Local vLLM / Ollama ===
# LLM_PROVIDER=local
# LLM_API_KEY=dummy
# LLM_MODEL=qwen2.5-72b-instruct
# LLM_BASE_URL=http://localhost:8000/v1

# === Global Overrides (optional, defaults shown) ===
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096
# AGENT_TIMEOUT_SECONDS=300

# === MCP Server (auto-detected, override if needed) ===
# MCP_SERVER_COMMAND=uv
# MCP_SERVER_DIR=../global-market-mcp
# MCP_SERVER_SCRIPT=mcp_server.py

# === Phase 4+: Web Search (Tavily) ===
# Free tier: 1000 credits/month. Sign up: https://app.tavily.com
# Future: support TAVILY_API_KEYS (comma-separated pool) for higher limits
TAVILY_API_KEY=your-tavily-api-key

# === Phase 4+: Telegram ===
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# === Phase 5: Web API ===
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_PASSWORD=change-me-to-a-strong-password
# ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
# VISITOR_DAILY_BUDGET=5
